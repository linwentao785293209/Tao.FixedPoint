# =============================================================================
# Tao.FixedPoint .gitignore
# 适用于: Unity + C# (.NET Standard / .NET Core)
# =============================================================================

# ========================== 操作系统 ==========================

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
~$*
*~

# macOS
.DS_Store

# ========================== IDE / 编辑器 ==========================

# JetBrains Rider / IntelliJ
.idea/
*.DotSettings.user
*.sln.iml

# Visual Studio
.vs/
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# Visual Studio Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace

# MonoDevelop / Xamarin Studio
*.userprefs

# ========================== .NET / C# 构建产物 ==========================

[Dd]ebug/
[Rr]elease/
[Bb]in/
[Oo]bj/
x64/
x86/
bld/
artifacts/
[Ll]og/
[Ll]ogs/

# NuGet
*.nupkg
*.snupkg
**/[Pp]ackages/*
!**/[Pp]ackages/build/
*.nuget.props
*.nuget.targets
project.lock.json
project.fragment.lock.json

# 编译中间文件
*.ilk
*.pch
*.pgc
*.pgd
*.rsp
*.sbr
*.tlb
*.tli
*.tlh
*.tmp
*.tmp_proj
*_wpftmp.csproj
*.tlog
*.vspscc
*.vssscc
.builds
*.pidb
*.svclog
*.scc

# 二进制日志
*.binlog

# Mono
mono_crash.*

# 测试结果
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*
*.VisualState.xml
TestResult.xml
nunit-*.xml

# 代码覆盖
*.dotCover
coverage*.json
coverage*.xml
coverage*.info
*.coverage
*.coveragexml

# ReSharper
_ReSharper*/
*.[Rr]e[Ss]harper

# NCrunch
_NCrunch_*
.*crunch*.local.xml
nCrunchTemp_*

# Benchmark
BenchmarkDotNet.Artifacts/

# 缓存
*.[Cc]ache
!?*.[Cc]ache/

# Fody
FodyWeavers.xsd

# ========================== Unity ==========================

# Unity 生成的目录
[Ll]ibrary/
[Tt]emp/
[Uu]ser[Ss]ettings/
[Mm]emoryCaptures/
[Rr]ecordings/

# Unity 自动生成的解决方案/项目文件（DotNet 目录下的真实项目文件不受影响）
Unity/**/*.csproj
Unity/**/*.sln
Unity/**/*.unityproj
Unity/**/*.booproj

# Unity 调试符号的 meta（这些不需要跟踪，其余 .meta 必须保留！）
*.pidb.meta
*.pdb.meta
*.mdb.meta

# Unity 崩溃报告
sysinfo.txt

# Unity 构建产物
*.apk
*.aab
*.unitypackage
*.unitypackage.meta
*.app

# Crashlytics
crashlytics-build.properties

# Unity TestRunner 自动生成场景
InitTestScene*.unity*
[Aa]ssets/[Ii]nit[Tt]est[Ss]cene*.unity*

# Addressables
[Aa]ssets/[Ss]treamingAssets/aa*
[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/*/*.bin*
[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/link.xml*
[Aa]ssets/[Aa]ddressables_[Tt]emp*

# Visual Scripting
[Aa]ssets/Unity.VisualScripting.Generated/

# Autogenerated Rider plugin in Unity
[Aa]ssets/Plugins/Editor/JetBrains*

# Blender 临时文件
*.blend1
*.blend1.meta

# Gradle
.gradle/

# 其他 Unity 相关
ExportedObj/
.consulo/
*.svd
*.mdb
*.opendb
*.VC.db
*.VC.VC.opendb

# ========================== 调试符号 ==========================

# PDB 文件（.NET 和 Unity 均不需要提交）
*.pdb
*.ipdb
*.iobj

# ========================== 其他 ==========================

# Local history
.localhistory/
.vshistory/
.history/

# MFractors
.mfractor/

# NVidia Nsight
*.nvuser
